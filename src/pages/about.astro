---
import BaseLayout from '../layouts/BaseLayout.astro';

const interests = [
  {
    title: 'Kubernetes & Container',
    keywords: ['K8s', 'Helm', 'Kustomize', 'ArgoCD', 'GitOps'],
  },
  {
    title: 'CI/CD & 자동화',
    keywords: ['GitHub Actions', '파이프라인', 'Self-hosted Runner'],
  },
  {
    title: 'Cloud & SDDC',
    keywords: ['OpenStack', 'Docker', 'Rancher', 'Cloudflare', 'OrbStack'],
  },
  {
    title: 'Network & SDN',
    keywords: ['NFV', 'SDN', 'Cisco APIC', 'Calico', 'DNS', 'VPN', 'BGP'],
  },
  {
    title: 'AI & Vibe Coding',
    keywords: ['Claude Code', 'LLM Gateway', 'A2A', 'MCP', 'Agent SDK'],
  },
  {
    title: '개발',
    keywords: ['TypeScript', 'Astro', 'Node.js', 'Java/Spring'],
  },
];

const techStack = [
  'Kubernetes', 'Docker', 'Helm', 'ArgoCD', 'Terraform',
  'GitHub Actions', 'TypeScript', 'Astro', 'Node.js',
  'Cloudflare', 'OpenStack', 'Linux', 'Calico', 'OrbStack',
];
---

<BaseLayout title="About | neocode24" description="neocode24 소개">
  <!-- 프로필 헤더 -->
  <section class="flex flex-col items-center text-center mb-10">
    <img
      src="https://avatars.githubusercontent.com/u/19453260?v=4"
      alt="neocode24 avatar"
      width="64"
      height="64"
      class="rounded-full mb-3"
    />
    <h1 class="text-2xl font-bold mb-1">neocode24</h1>
    <p class="text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) mb-3">
      Cloud 인프라 &middot; DevOps &middot; Vibe Coder
    </p>
    <a
      href="https://github.com/neocode24"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1.5 text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) hover:text-(--color-accent) dark:hover:text-(--color-dark-accent) transition-colors"
      aria-label="GitHub 프로필"
    >
      <!-- Lucide: Github -->
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
        <path d="M9 18c-4.51 2-5-2-7-2" />
      </svg>
      GitHub
    </a>
  </section>

  <!-- 관심 분야 -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4">관심 분야</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {interests.map((item, i) => (
        <div class="bg-(--color-bg-secondary) dark:bg-(--color-dark-bg-secondary) rounded-lg p-4">
          <div class="flex items-center gap-2 mb-2">
            <div class="text-(--color-accent) dark:text-(--color-dark-accent)">
              {i === 0 && (
                /* Lucide: Container */
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 7.7c0-.6-.4-1.2-.8-1.5l-6.3-3.9a1.72 1.72 0 0 0-1.7 0l-10.3 6c-.5.2-.9.8-.9 1.4v6.6c0 .5.4 1.2.8 1.5l6.3 3.9a1.72 1.72 0 0 0 1.7 0l10.3-6c.5-.3.9-1 .9-1.5Z" />
                  <path d="M10 21.9V14L2.1 9.1" />
                  <path d="m10 14 11.9-6.9" />
                  <path d="M14 19.8v-8.1" />
                  <path d="M18 17.5V9.4" />
                </svg>
              )}
              {i === 1 && (
                /* Lucide: GitBranch */
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 6a9 9 0 0 0-9 9V3" />
                  <circle cx="18" cy="6" r="3" />
                  <circle cx="6" cy="18" r="3" />
                </svg>
              )}
              {i === 2 && (
                /* Lucide: Cloud */
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z" />
                </svg>
              )}
              {i === 3 && (
                /* Lucide: Network */
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="16" y="16" width="6" height="6" rx="1" />
                  <rect x="2" y="16" width="6" height="6" rx="1" />
                  <rect x="9" y="2" width="6" height="6" rx="1" />
                  <path d="M5 16v-3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v3" />
                  <path d="M12 12V8" />
                </svg>
              )}
              {i === 4 && (
                /* Lucide: Sparkles */
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z" />
                  <path d="M20 2v4" />
                  <path d="M22 4h-4" />
                  <circle cx="4" cy="20" r="2" />
                </svg>
              )}
              {i === 5 && (
                /* Lucide: Code */
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m16 18 6-6-6-6" />
                  <path d="m8 6-6 6 6 6" />
                </svg>
              )}
            </div>
            <h3 class="font-medium text-sm">{item.title}</h3>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {item.keywords.map((kw) => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-(--color-bg) dark:bg-(--color-dark-bg) text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
                {kw}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 기술 스택 -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4">기술 스택</h2>
    <div class="flex flex-wrap gap-1.5">
      {techStack.map((tech) => (
        <span class="text-xs px-2 py-0.5 rounded-full bg-(--color-bg-secondary) dark:bg-(--color-dark-bg-secondary) text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
          {tech}
        </span>
      ))}
    </div>
  </section>

  <!-- 이 블로그 -->
  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4">이 블로그</h2>
    <div class="bg-(--color-bg-secondary) dark:bg-(--color-dark-bg-secondary) rounded-lg p-4 text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) space-y-1">
      <p>Astro SSG + Tailwind CSS</p>
      <p>GitHub Pages + Cloudflare DNS</p>
      <p>Giscus 댓글 (GitHub Discussions)</p>
    </div>
  </section>
</BaseLayout>
