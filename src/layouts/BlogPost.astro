---
import BaseLayout from './BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RecentPosts from '../components/RecentPosts.astro';
import TagCloud from '../components/TagCloud.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  headings?: Heading[];
  currentSlug?: string;
}

const { title, description, pubDate, updatedDate, tags = [], headings = [], currentSlug } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title={`${title} | neocode24`} description={description} wide>
  <!-- JSON-LD 구조화 데이터 -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "datePublished": pubDate.toISOString(),
    ...(updatedDate && { "dateModified": updatedDate.toISOString() }),
    "author": {
      "@type": "Person",
      "name": "neocode24",
      "url": "https://github.com/neocode24"
    },
    "publisher": {
      "@type": "Person",
      "name": "neocode24"
    },
    ...(tags.length > 0 && { "keywords": tags.join(", ") })
  })} />

  <div class="lg:grid lg:grid-cols-[1fr_14rem] lg:gap-8">
    <div class="min-w-0">
      <article>
        <header class="mb-8 border-b border-(--color-border) dark:border-(--color-dark-border) pb-6">
          <h1 class="text-3xl font-bold mb-3">{title}</h1>
          <div class="flex items-center gap-3 text-sm text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
            <time datetime={pubDate.toISOString()}>
              {formatDate(pubDate)}
            </time>
            {updatedDate && (
              <span>
                (수정: {formatDate(updatedDate)})
              </span>
            )}
          </div>
          {tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-3">
              {tags.map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-(--color-bg-secondary) dark:bg-(--color-dark-bg-secondary) text-(--color-text-secondary) dark:text-(--color-dark-text-secondary)">
                  {tag}
                </span>
              ))}
            </div>
          )}
        </header>
        <div class="prose dark:prose-invert">
          <slot />
        </div>
      </article>
      <Giscus />
    </div>

    <aside class="hidden lg:block">
      <div class="sticky top-20 space-y-8">
        <TableOfContents headings={headings} />
        <RecentPosts currentSlug={currentSlug} />
        <TagCloud />
      </div>
    </aside>
  </div>

  <script>
    async function initMermaid() {
      const blocks = document.querySelectorAll('pre[data-language="mermaid"]');
      if (blocks.length === 0) return;

      const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
      const isDark = document.documentElement.classList.contains('dark');
      mermaid.initialize({ startOnLoad: false, theme: isDark ? 'dark' : 'default' });

      for (const pre of blocks) {
        const code = pre.querySelector('code');
        const container = document.createElement('div');
        container.className = 'mermaid';
        container.textContent = code ? code.textContent! : pre.textContent!;
        pre.replaceWith(container);
      }

      await mermaid.run({ nodes: document.querySelectorAll('.mermaid') });
    }

    initMermaid();
    document.addEventListener('astro:after-swap', initMermaid);
  </script>
</BaseLayout>
