---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{toc.length > 0 && (
  <nav class="toc" aria-label="목차">
    <h2 class="text-sm font-semibold mb-3 text-(--color-text) dark:text-(--color-dark-text)">
      목차
    </h2>
    <ul class="space-y-1.5 text-sm">
      {toc.map((heading) => (
        <li class:list={[heading.depth === 3 && "pl-3"]}>
          <a
            href={`#${heading.slug}`}
            class="toc-link block py-0.5 text-(--color-text-secondary) dark:text-(--color-dark-text-secondary) hover:text-(--color-accent) dark:hover:text-(--color-dark-accent) transition-colors leading-snug"
            data-slug={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  function initToc() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (links.length === 0) return;

    const slugs = Array.from(links).map((link) => link.dataset.slug!);
    const headingElements = slugs
      .map((slug) => document.getElementById(slug))
      .filter(Boolean) as HTMLElement[];

    if (headingElements.length === 0) return;

    let activeSlug = '';

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            activeSlug = entry.target.id;
            break;
          }
        }
        links.forEach((link) => {
          link.classList.toggle('active', link.dataset.slug === activeSlug);
        });
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );

    headingElements.forEach((el) => observer.observe(el));
  }

  initToc();
  document.addEventListener('astro:after-swap', initToc);
</script>
